{
  "layer": "top",
  "position": "top",
  "height": 28,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network"],

  "clock": {
    "format": "{:%Y-%m-%d %H:%M}",
    "tooltip": false
  },

  "cpu": {
    "format": "CPU {usage}%",
    "tooltip": false
  },

  "memory": {
    "format": "RAM {used:0.1f}G",
    "tooltip": false
  },

  "network": {
    "format-wifi": "NET {essid}",
    "format-ethernet": "ETH",
    "format-disconnected": "OFF"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTED"
  }
}
